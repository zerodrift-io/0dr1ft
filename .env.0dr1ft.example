# 0dr1ft — ZeroDrift AI Automation
# Environment configuration for 0dr1ft deployment
#
# Copy to `.env.0dr1ft` and fill in your values.
# These are loaded BEFORE the standard OpenClaw .env, giving them priority.

# ---------------------------------------------------------------------------
# Gateway
# ---------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# ---------------------------------------------------------------------------
# AI Provider (Groq Llama 3.3 70B — ZeroDrift default stack)
# ---------------------------------------------------------------------------
# GROQ_API_KEY=gsk_...

# Alternative providers
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Channels
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...

# ---------------------------------------------------------------------------
# Azure deployment (resource prefix: 0dr1ft)
# ---------------------------------------------------------------------------
# AZURE_SUBSCRIPTION_ID=
# AZURE_RESOURCE_GROUP=0dr1ft-rg
# AZURE_LOCATION=francecentral
