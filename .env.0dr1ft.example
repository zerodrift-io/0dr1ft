# ── 0dr1ft Environment Config ────────────────────────────────────────────────
# Copy this file to .env.0dr1ft and fill in your values.
# Variables here are loaded before OpenClaw starts (non-overriding — shell env wins).
#
# GitHub is source of truth: commit changes to .env.0dr1ft.example, never .env.0dr1ft

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary: Groq (fast inference)
GROQ_API_KEY=

# Fallback / extended context
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Gateway ───────────────────────────────────────────────────────────────────
# Token required to connect clients to this gateway (leave empty to disable auth)
OPENCLAW_GATEWAY_TOKEN=

# Port the gateway listens on (default: 3000)
# PORT=3000

# ── Channels ──────────────────────────────────────────────────────────────────
# Discord bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Slack app
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Azure (populated automatically by infra/azure/deploy.sh) ──────────────────
# Set by the deploy workflow — do not set manually in production
# AZURE_STORAGE_ACCOUNT=0dr1ftdata
# AZURE_STORAGE_KEY=

# ── ZeroDrift Identity ────────────────────────────────────────────────────────
# Branding injected into the assistant's system prompt
OPENCLAW_ASSISTANT_NAME=0dr1ft
# OPENCLAW_SYSTEM_PROMPT_APPEND="You are 0dr1ft, ZeroDrift's AI assistant."
